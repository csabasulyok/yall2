{
  "name": "yall2",
  "version": "1.4.1",
  "description": "Yet Another Logging Library",
  "author": "Csaba Sulyok <csaba.sulyok@gmail.com>",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csabasulyok/yall2.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
    "build": "tsc -p tsconfig.build.json",
    "cb": "pnpm clean && pnpm build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.ts' --config ./.prettierrc.yml",
    "format:check": "prettier --check .",
    "ci": "pnpm lint && pnpm format && pnpm build",
    "publish:local": "pnpm publish --verbose --registry=http://localhost:8081/repository/npm-releases/",
    "publish:npmjs": "pnpm publish --verbose --registry=https://registry.npmjs.org/",
    "example": "tsx test/yall.example.ts",
    "example:morgan": "tsx test/yallmorgan.example.ts",
    "example:axios": "tsx test/yallaxios.example.ts"
  },
  "dependencies": {
    "auto-bind": "5.0.1",
    "axios": "1.13.6",
    "express": "5.2.1",
    "extol": "1.4.3",
    "morgan": "1.10.1",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "24.12.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unicorn": "63.0.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "npm run lint",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
